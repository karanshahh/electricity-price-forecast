# Electricity Price Forecast - Environment Variables
# Copy to .env and fill in values

# PJM API (required for LMP fetch). Register at https://apiportal.pjm.com/
PJM_API_KEY=

# MLflow tracking
MLFLOW_TRACKING_URI=./mlruns

# Application settings
API_HOST=0.0.0.0
API_PORT=8000

# Data paths (optional overrides)
# DATA_RAW_DIR=data/raw
# DATA_PROCESSED_DIR=data/processed
